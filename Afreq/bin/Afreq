#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AFREQ_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ESTIMATE_SCRIPT="$AFREQ_DIR/scripts/compute_allelic_freqs.sh"

print_help() {
    "$ESTIMATE_SCRIPT" --usage-name "Afreq estimate" --help
}

cmd="${1:-help}"

case "$cmd" in
    estimate)
        shift
        exec "$ESTIMATE_SCRIPT" --usage-name "Afreq estimate" "$@"
        ;;
    help|-h|--help)
        print_help
        ;;
    *)
        echo "Error: unknown Afreq command '$cmd'" >&2
        print_help >&2
        exit 1
        ;;
esac
