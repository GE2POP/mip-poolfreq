script_dir <- "~/GitHub/mip-poolfreq/scripts/genotypeFreqEstimation/scripts" #dirname(this.path::this.path())
project_root <- normalizePath(file.path(script_dir, ".."))
setwd(project_root)
load_all(".")
required_files=c(genotyping_vcf_path=genotyping_vcf_path, lib_names_corresp_path=lib_names_corresp_path,
allele_freqs_paths, snp_depths_paths, expected_freqs_paths, tkw_paths)
check_input_files(
required_files = required_files
)
## Import input files
genotyping_matrix<-vcf_to_numeric_matrix(
vcf_path = genotyping_vcf_path,
lib_names_corresp_path = lib_names_corresp_path
)
allele_freqs_dfs<-c()
snp_depths_dfs<-c()
expected_freqs_dfs<-c()
tkw_dfs<-c()
for (dataset in c("main", "extra")){
allele_freqs<-read.table(allele_freqs_paths[dataset], header=T)
snp_depths<-read.table(snp_depths_paths[dataset], header=T)
expected_freqs<-read.table(expected_freqs_paths[dataset], header=T)
tkw<-read.table(tkw_paths[dataset], header=T)[,c("Mixture","Component","Origin","TKW")]
allele_freqs_dfs[[dataset]]<-allele_freqs
snp_depths_dfs[[dataset]]<-snp_depths
expected_freqs_dfs[[dataset]]<-expected_freqs
tkw <- tkw %>%
group_by(Mixture) %>%
mutate(
mean_TKW = mean(TKW, na.rm = TRUE),
diff_TKW = TKW - mean_TKW
) %>%
ungroup()
tkw_dfs[[dataset]]<-tkw
}
equiprop_mixtures<-c(subset(expected_freqs_dfs[[1]], EL4X_199==0.25 & GQ4X_83==0.25 & EL4X_35==0.25)$Mixture,
subset(expected_freqs_dfs[[2]], EL4X_199==0.25 & GQ4X_83==0.25 & EL4X_35==0.25)$Mixture)
allele_freqs<-merge(allele_freqs_dfs[[1]], allele_freqs_dfs[[2]])
allele_freqs<-set_rownames_from_chrom_pos(allele_freqs)
allele_freqs<-allele_freqs[, equiprop_mixtures]
snp_depths<-merge(snp_depths_dfs[[1]], snp_depths_dfs[[2]])
snp_depths<-set_rownames_from_chrom_pos(snp_depths)
snp_depths<-snp_depths[, equiprop_mixtures]
expected_freqs<-rbind(expected_freqs_dfs[[1]], expected_freqs_dfs[[2]])
expected_freqs<-subset(expected_freqs, Mixture %in% equiprop_mixtures)
expected_freqs_melt<-melt_genotype_freqs(expected_freqs, "ExpFreq")
tkw<-rbind(tkw_dfs[[1]], tkw_dfs[[2]])
tkw<-subset(tkw, Mixture %in% equiprop_mixtures)
# Estimate genotype frequencies and compute biases
genotype_frequencies_mixtures<-estimate_genotype_freqs(
genotyping_matrix = genotyping_matrix,
allele_freqs = allele_freqs,
snp_depths = snp_depths,
expected_freqs_melt = expected_freqs_melt
)
errors<-compute_errors(
freqs_df = genotype_frequencies_mixtures
)
errors_TKW<-merge(errors, tkw)
ggplot(errors_TKW, aes(x = diff_TKW, y = error_EstFreq, color = Component)) +
geom_point(size = 3) +
geom_hline(yintercept = 0, color = "grey40", linetype = "dashed", linewidth = 0.6) +
geom_vline(xintercept = 0, color = "grey40", linetype = "dashed", linewidth = 0.6) +
labs(
x = "Component TKW deviation from mixture mean",
y = "Estimate error",
color = "Component"
) +
theme_bw(base_size = 16)
### Modèle à 3 effets
# Tester l'effet fixe (diff_TKW) >> REML = TRUE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = TRUE)
#### Version rigoureuse d'après Doudou
library(lme4)
### Modèle à 3 effets
# Tester l'effet fixe (diff_TKW) >> REML = TRUE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = TRUE)
m1 <- lmer(error_EstFreq ~ 1 + (1|Component) + (1|Origin),
data = errors_TKW, REML = TRUE)
KRmodcomp(m0, m1)
library(pbkrtest)
KRmodcomp(m0, m1)
## Tester les effets aléatoires par bootstrap paramétrique en ML (Component et Origin) >> REML = FALSE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = FALSE)
m1 <- lmer(error_EstFreq ~ diff_TKW + (1|Origin),
data = errors_TKW, REML = FALSE)
m2 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
PBmodcomp(m0, m1, nsim = 200)
PBmodcomp(m0, m1, nsim = 20)
PBmodcomp(m0, m1, nsim = 200)
PBmodcomp(m0, m1, nsim = 2000)
PBmodcomp(m0, m2, nsim = 2000) # test d'origin
### Modèle sans Origin
## Tester l'effet fixe (diff_TKW) >> REML = TRUE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = TRUE)
m1 <- lmer(error_EstFreq ~ 1 + (1|Component),
data = errors_TKW, REML = TRUE)
KRmodcomp(m0, m1) #pvalue = 2.347e-05
## Tester l'effet aléatoire par bootstrap paramétrique en ML (Component) >> REML = FALSE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
m1 <- lmer(error_EstFreq ~ diff_TKW,
data = errors_TKW, REML = FALSE)
m1 <- lm(error_EstFreq ~ diff_TKW,
data = errors_TKW, REML = FALSE)
## Tester l'effet aléatoire par bootstrap paramétrique en ML (Component) >> REML = FALSE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
m1 <- lm(error_EstFreq ~ diff_TKW,
data = errors_TKW)
PBmodcomp(m0, m1, nsim = 2000) # test de component > pvalue = 0.0009398
## Tester l'effet aléatoire par bootstrap paramétrique en ML (Component) >> REML = FALSE
# NB : on ne peux pas faire un lmer() sur un modèle sans effet aléatoire et on ne peut pas appliquer PBmodcomp()
#      sur 2 modèles de classe différente (lm et lmer) donc on utilise exactRLRT() à la place
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
exactRLRT(m0)
library(RLRsim)
exactRLRT(m0)
## Tester l'effet aléatoire par bootstrap paramétrique en ML (Component) >> REML = FALSE
# NB : on ne peux pas faire un lmer() sur un modèle sans effet aléatoire et on ne peut pas appliquer PBmodcomp()
#      sur 2 modèles de classe différente (lm et lmer) donc on utilise exactRLRT() à la place
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = TRUE)
exactRLRT(m0) # test de component > p-value < 2.2e-16
fixef(m0)["diff_TKW"]
confint(m0, parm = "diff_TKW", method = "Wald")   # ou "profile" si possible
VarCorr(m0)
isSingular(m0, tol = 1e-5)
length(getME(m0, "flist")$Component)
exactRLRT(m0) # test de component > p-value < 2.2e-16
set.seed(42)
library(lme4)
library(RLRsim)
library(pbkrtest)
### Modèle à 3 effets
## Tester l'effet fixe (diff_TKW) >> REML = TRUE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = TRUE)
m1 <- lmer(error_EstFreq ~ 1 + (1|Component) + (1|Origin),
data = errors_TKW, REML = TRUE)
KRmodcomp(m0, m1) #pvalue = 2.347e-05
## Tester les effets aléatoires par bootstrap paramétrique en ML (Component et Origin) >> REML = FALSE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = FALSE)
m1 <- lmer(error_EstFreq ~ diff_TKW + (1|Origin),
data = errors_TKW, REML = FALSE)
m2 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
PBmodcomp(m0, m1, nsim = 2000) # test de component > pvalue = 0.0009398
PBmodcomp(m0, m2, nsim = 2000) # test d'origin > pvalue = 0.1227
### Modèle sans Origin
## Tester l'effet fixe (diff_TKW) >> REML = TRUE
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = TRUE)
m1 <- lmer(error_EstFreq ~ 1 + (1|Component),
data = errors_TKW, REML = TRUE)
KRmodcomp(m0, m1) #pvalue = 1.312e-07
## Tester l'effet aléatoire (Component) par test exact de la variance >> REML = TRUE
# NB : on ne peux pas faire un lmer() sur un modèle sans effet aléatoire et on ne peut pas appliquer PBmodcomp()
#      sur 2 modèles de classe différente (lm et lmer) donc on utilise exactRLRT() à la place
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = TRUE)
exactRLRT(m0) # test de component > p-value < 2.2e-16
# Effets du modèle final
summary(m0)
fixef(m0)
ranef(m0)
coef(m0)
anova(m0)
fixef(m0)["diff_TKW"]
confint(m0, parm = "diff_TKW", method = "Wald")   # ou "profile" si possible
VarCorr(m0)
isSingular(m0, tol = 1e-5)
length(getME(m0, "flist")$Component)
PBmodcomp(m0, m2, nsim = 20000) # test d'origin > pvalue = 0.1227
m0 <- lmer(error_EstFreq ~ diff_TKW + (1|Component) + (1|Origin),
data = errors_TKW, REML = FALSE)
m1 <- lmer(error_EstFreq ~ diff_TKW + (1|Origin),
data = errors_TKW, REML = FALSE)
m2 <- lmer(error_EstFreq ~ diff_TKW + (1|Component),
data = errors_TKW, REML = FALSE)
PBmodcomp(m0, m2, nsim = 20000) # test d'origin > pvalue = 0.1227
