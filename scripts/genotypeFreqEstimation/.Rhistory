p<-0.5
q<-1-p
t <-0.01
n<-120
FisVrai <- (1-t)/(1+t)
Sim <-c()
for (i in 1:10000) {
A1<-rbinom(n,1,p)
HomoZ <- rbinom(n, 1, FisVrai)
A2 <- A1 * (HomoZ==1) +  rbinom(1, 1,0.5)*(HomoZ==0)
G<-cbind(A1, A2)
pprim<-sum(G)/(ncol(G)*nrow(G))
qprim<-1-pprim
HeAtt=2*pprim*qprim
GOBS<-as.data.frame(G)
HeObs <- sum((GOBS$A1 + GOBS$A2)==1)/nrow(G)
Fis<-1-HeObs/HeAtt
Sim[i]<-Fis }
hist(Sim, main = paste0("Distribution of FIS values for t = ", t),
xlab = "FIS", ylab = "Count", xlim=c(0.75, 1))
abline(v = mean(Sim), col = "darkblue", lwd = 2)
text(mean(Sim)-0.035, 2000, paste0("Mean FIS = ", round(mean(Sim), 2)), col = "darkblue")
abline(v = 0.8, col = "darkred", lwd = 2)
text(0.8+0.03, 300, paste0("0.8 threshold"), col = "darkred")
mean(Sim)-2*sd(Sim)
